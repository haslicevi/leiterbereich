    <ul class="list-group">
        <li style="cursor: pointer;" class="list-group-item" onClick="window.location.href = 'https://login.haslicevi.ch{{ path('newsletter_public',{'id': mail.id}) }}';">{{ mail.betreff }}</li>
    </ul>
{% endfor %} #}
{% endapply %}