{% extends 'base.html.twig' %}

{% block pagetitle %}Formulare{% endblock %}

{% block body %}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Formulare</h6>
    </div>
    <div class="card-body">
        <a href="{{ path('newsletter_new') }}" class="btn btn-info btn-icon-split mb-3">
            <span class="icon text-white-50">
                <i class="fas fa-plus"></i>
            </span>
            <span class="text">Neues Formular</span>
        </a>
        <a href="{{ path('newsletter_vorlage') }}" class="btn btn-info btn-icon-split mb-3 ml-2">
            <span class="icon text-white-50">
                <i class="fas fa-plus"></i>
            </span>
            <span class="text">Neu aus Vorlage</span>
        </a>
        {{ dump(json) }}
    </div>
</div>
{% endblock %}