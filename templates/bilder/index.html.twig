{% extends 'base.html.twig' %}

{% block pagetitle %}Bilder{% endblock %}

{% block body %}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Bilder</h6>
    </div>
    <div class="card-body">
        <div class="card shadow mb-4 border-bottom-warning">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">Info</h6>
            </div>
            <div class="card-body">
                 <p>Im internen Bilderarchiv sind alle Bilder des Haslicevi in Originalqualität abgelegt.</p>
                {#<form action="{{ url }}" method="post" target="_blank">
                    <input type="hidden" name="passwd" value="{{ loginData.pw }}">
                    <button type="submit" class="btn btn-primary btn-icon-split mb-3">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-right"></i>
                        </span>
                        <span class="text">zum Bilderarchiv</span>
                    </button>
                </form>#}
            </div>
        </div>
        <h5>Zugangsdaten</h5>
        <table class="table table-striped">
            <tbody>
                <tr>
                    <th scope="row" width="20%">Link</th>
                    <td><a href="{{ url }}" target="_blank">zum Bilderarchiv</a></td>
                </tr>
                <tr>
                    <th scope="row">Passwort</th>
                    <td>{{ loginData.pw }}</td>
                </tr>
            </tbody>
        </table>
    </div>
</div>
{% endblock %}