{% extends 'base.html.twig' %}

{% block pagetitle %}Mailserver{% endblock %}

{% block body %}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Mail-Adressen verwalten</h6>
    </div>
    <div class="card-body">
        <div class="card shadow mb-4 border-bottom-warning">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">Info</h6>
            </div>
            <div class="card-body">
                <p>Die Mailadressen-Verwaltung findet im Interface des Webservers statt.</p>
                <form action="https://103.hosttech.eu:8443/login_up.php" method="post" target="_blank">
                    <input type="hidden" name="login_name" value="{{ user }}">
                    <input type="hidden" name="passwd" value="{{ pw }}">
                    <button type="submit" class="btn btn-primary btn-icon-split mb-3">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-right"></i>
                        </span>
                        <span class="text">zum Plesk</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>
{% endblock %}