{% extends 'base.html.twig' %}

{% block pagetitle %}Anwesenheiten{% endblock %}

{% block body %}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Leiter Anwesenheiten</h6>
    </div>
    <div class="card-body">
        <a href="{{ path('anwesenheiten_leiter_verteilen') }}" class="btn btn-info btn-icon-split mb-3">
            <span class="icon text-white-50">
                <i class="fas fa-list"></i>
            </span>
            <span class="text">Eintragen</span>
        </a>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th scope="col">Name</th>
                    <th scope="col">anwesend {{ jahre[0] }}</th>
                    <th scope="col">anwesend {{ jahre[1] }}</th>
                </tr>
            </thead>
            <tbody>
                {% for lt, anz in leiter %}
                    <tr>
                        <td>{{ lt }}</td>
                        <td>{{ anz[0] }}</td>
                        <td>{{ anz[1] }}</td>
                    </td>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>
{% endblock %}