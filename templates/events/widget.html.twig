{% apply spaceless %}
<h4 class="widget-title">Agenda</h4>
<ul>
    {% for event in events %}
        <li>
            {% if event.typ == 1 %}
                {# <a href="javascript:void(0)">{{ event.von|date('d.m.Y') }} - Programm</a> #}
                {{ event.von|date('d.m.Y') }} - Programm
            {% else %}
                {% if event.link %}
                    <a href="{{ event.link }}">{{ event.von|date('d.m.Y') }} - {{ event.name }}</a>
                {% else %}
                    {# <a href="javascript:void(0)">{{ event.von|date('d.m.Y') }} - {{ event.name }}</a> #}
                    {{ event.von|date('d.m.Y') }} - {{ event.name }}
                {% endif %}
            {% endif %}
        </li>
    {% endfor %}
    <li>
        <a href="https://haslicevi.ch/agenda">-- mehr anzeigen --</a>
    </li>
</ul>
{% endapply %}