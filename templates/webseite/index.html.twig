{% extends 'base.html.twig' %}

{% block pagetitle %}Webseite{% endblock %}

{% block body %}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Webseite bearbeiten</h6>
    </div>
    <div class="card-body">
        <div class="card shadow mb-4 border-bottom-warning">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">Info</h6>
            </div>
            <div class="card-body">
                 <p>Die Bearbeitung der Webseite findet in einem anderen Tool statt:</p>
                <form action="{{ url }}wp-login.php" method="post" target="_blank">
                    <input type="hidden" name="redirect_to" value="{{ url }}wp-admin/edit.php">
                    <input type="hidden" name="log" value="{{ loginData.user }}">
                    <input type="hidden" name="pwd" value="{{ loginData.pw }}">
                    <button type="submit" class="btn btn-primary btn-icon-split mb-3">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-right"></i>
                        </span>
                        <span class="text">zum CMS</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

{% if is_granted('ROLE_ADMIN') %}
<div class="card shadow mb-4">
    <div class="card-header py-3">
        <h6 class="m-0 font-weight-bold text-primary">Bildergalerie bearbeiten</h6>
    </div>
    <div class="card-body">
        <div class="card shadow mb-4 border-bottom-warning">
            <div class="card-header py-3">
                <h6 class="m-0 font-weight-bold text-warning">Info</h6>
            </div>
            <div class="card-body">
                <p>Die Bearbeitung der Bildergalerie findet in einem anderen Tool statt:</p>
                <form action="https://bilder.haslicevi.ch/h3k.php" method="post" target="_blank">
                    <input type="hidden" name="fm_usr" value="{{ bildergalerie.user }}">
                    <input type="hidden" name="fm_pwd" value="{{ bildergalerie.pw }}">
                    <button type="submit" class="btn btn-primary btn-icon-split mb-3">
                        <span class="icon text-white-50">
                            <i class="fas fa-arrow-right"></i>
                        </span>
                        <span class="text">zur Bildergalerie</span>
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

